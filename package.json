{
  "name": "insucare-enterprise-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready insurance broking website and API for Insucare India Insurance Broking Pvt Ltd.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@insucare/web",
    "dev:api": "npm run dev --workspace=@insucare/api",
    "build": "npm run build --workspaces --if-present",
    "build:api": "npm run build -w @insucare/domain && npm run build -w @insucare/api",
    "build:web": "npm run build -w @insucare/domain && npm run build -w @insucare/web",
    "start": "npm run start:api",
    "start:api": "npm run start -w @insucare/api",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate --workspace=@insucare/api",
    "prisma:migrate": "npm run prisma:migrate --workspace=@insucare/api",
    "seed": "npm run seed --workspace=@insucare/api"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
